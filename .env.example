DJANGO_READ_DOT_ENV_FILE=True
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

OPENAI_API_KEY=
# For OpenRouter: https://openrouter.ai/api/v1
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20

# Without EMAIL_HOST letters are saved only to storage/mail/
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=20
DJANGO_DEFAULT_FROM_EMAIL=Developer Landing <noreply@localhost>
CONTACT_OWNER_EMAIL=owner@example.com

# Recommended for demo / Render: Resend HTTPS API
# (EMAIL_HOST=smtp.resend.com switches code to api.resend.com; password = API key)
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxxxx
# DJANGO_DEFAULT_FROM_EMAIL=Developer Landing <onboarding@resend.dev>
# CONTACT_OWNER_EMAIL=you@example.com
# Without a verified domain Resend only delivers to the account email:
# EMAIL_DEMO_FORCE_TO=you@example.com

RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=900

CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=

# Render / production extras
# DJANGO_SETTINGS_MODULE=config.settings.render
# DJANGO_SECURE_SSL_REDIRECT=True
# PUBLIC_API_URL=https://your-app.onrender.com
